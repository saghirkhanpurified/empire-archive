generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("POSTGRES_PRISMA_URL")
  directUrl = env("POSTGRES_URL_NON_POOLING")
}

model Article {
  id        Int      @id @default(autoincrement())
  slug      String   @unique
  title     String
  content   String   
  createdAt DateTime @default(now())
}

model HistoryEvent {
  id        Int      @id @default(autoincrement())
  year      String
  title     String
  desc      String
  createdAt DateTime @default(now())
}