generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Article {
  id        Int      @id @default(autoincrement())
  slug      String   @unique
  title     String
  content   String   
  createdAt DateTime @default(now())
}

model HistoryEvent {
  id        Int      @id @default(autoincrement())
  year      String
  title     String
  desc      String
  createdAt DateTime @default(now())
}